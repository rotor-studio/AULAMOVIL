[Unit]
Description=Rotor Meteo Collector
After=network.target mosquitto.service
Wants=mosquitto.service

[Service]
Type=simple
User=aulamovil
WorkingDirectory=/opt/rotor-meteo
ExecStart=/opt/rotor-meteo/.venv/bin/python /opt/rotor-meteo/collector/collector.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
